# Fusionix — Phase 1 (core + local CLI) environment.
# Copy to .env and fill in. Only OPENROUTER_API_KEY is required for `fusionix --local`.

# Gateway key used for model calls in --local mode. Required.
OPENROUTER_API_KEY=

# Optional: override the gateway base URL (default: https://openrouter.ai/api/v1).
# FUSIONIX_DEFAULT_GATEWAY=https://openrouter.ai/api/v1

# Optional: override the default preset (default: general-high).
# FUSIONIX_DEFAULT_PRESET=general-high

# Optional: path to an external config file (otherwise ./fusionix.config.json is auto-discovered).
# FUSIONIX_CONFIG=./fusionix.config.json

# Optional: OpenRouter attribution headers (appear in OpenRouter app rankings).
# FUSIONIX_HTTP_REFERER=https://fusionix.ikangai.com
# FUSIONIX_APP_TITLE=Fusionix

# --- Later phases (not used by Phase 1) ---
# FUSIONIX_API_KEY=            # hosted client auth (Phase 2+)
# FUSIONIX_ENCRYPTION_KEY=     # AEAD key for stored gateway secrets (Phase 2+)
# FUSIONIX_GATEWAY_SECRET=     # used only by fusionix-admin set-gateway-key (Phase 2+)
# FUSIONIX_LOG_LEVEL=info

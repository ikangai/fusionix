# Fusion — Phase 1 (core + local CLI) environment.
# Copy to .env and fill in. Only OPENROUTER_API_KEY is required for `fusion --local`.

# Gateway key used for model calls in --local mode. Required.
OPENROUTER_API_KEY=

# Optional: override the gateway base URL (default: https://openrouter.ai/api/v1).
# FUSION_DEFAULT_GATEWAY=https://openrouter.ai/api/v1

# Optional: override the default preset (default: general-high).
# FUSION_DEFAULT_PRESET=general-high

# Optional: path to an external config file (otherwise ./fusion.config.json is auto-discovered).
# FUSION_CONFIG=./fusion.config.json

# Optional: OpenRouter attribution headers (appear in OpenRouter app rankings).
# FUSION_HTTP_REFERER=https://fusion.ikangai.com
# FUSION_APP_TITLE=Fusion

# --- Later phases (not used by Phase 1) ---
# FUSION_API_KEY=            # hosted client auth (Phase 2+)
# FUSION_ENCRYPTION_KEY=     # AEAD key for stored gateway secrets (Phase 2+)
# FUSION_GATEWAY_SECRET=     # used only by fusion-admin set-gateway-key (Phase 2+)
# FUSION_LOG_LEVEL=info
